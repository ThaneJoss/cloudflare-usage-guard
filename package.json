{
  "name": "cloudflare-usage-guard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev --config worker/wrangler.jsonc",
    "build": "pnpm typecheck && vite build",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "worker:types": "wrangler types worker/worker-configuration.d.ts --config worker/wrangler.jsonc",
    "worker:dry-run": "wrangler deploy --dry-run --config worker/wrangler.jsonc --secrets-file worker/.dev.vars.example",
    "deploy:worker": "wrangler deploy --config worker/wrangler.jsonc",
    "deploy:pages": "wrangler pages deploy dist --project-name cloudflare-usage-guard",
    "deploy": "pnpm --filter cloudflare-usage-guard... run build && wrangler deploy",
    "preview": "pnpm --filter cloudflare-usage-guard... run build && wrangler dev"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.14.0",
  "dependencies": {
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
